# Local testing only — never commit real credentials.
# Used when running actions outside Activepieces (e.g. manual API smoke tests).

PLANNING_CENTER_APP_ID=your_personal_access_token_client_id
PLANNING_CENTER_SECRET=your_personal_access_token_secret

# Optional: override the User-Agent sent to Planning Center
PLANNING_CENTER_USER_AGENT=activepieces-custom-pieces/planning-center (local-dev)